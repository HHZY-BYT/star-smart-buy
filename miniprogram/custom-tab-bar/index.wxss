.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-text {
  font-size: 24rpx;
  color: #999999;
}

.tab-icon.active {
  transform: scale(1.1);
}

.tab-text.active {
  color: #1890ff;
  font-weight: 500;
}
