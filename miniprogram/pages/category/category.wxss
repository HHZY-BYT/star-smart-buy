/* pages/category/category.wxss */
.category-page {
  display: flex;
  min-height: 100vh;
  background-color: #f5f7fa;
}

/* ===== 分类侧边栏 ===== */
.category-sidebar {
  width: 180rpx;
  background-color: #f0f2f5;
  height: 100vh;
}

.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx;
  position: relative;
  transition: all 0.2s ease;
}

.sidebar-item:active {
  background-color: #fff;
}

.sidebar-item.active {
  background-color: #fff;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 6rpx 6rpx 0;
}

.sidebar-icon {
  font-size: 38rpx;
  margin-bottom: 8rpx;
}

.sidebar-name {
  font-size: 23rpx;
  color: #666;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}

.sidebar-item.active .sidebar-name {
  color: #667eea;
  font-weight: 600;
}

/* ===== 商品内容区 ===== */
.product-content {
  flex: 1;
  background-color: #fff;
  height: 100vh;
}

/* ===== 子分类标签栏 ===== */
.sub-category-bar {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 16rpx 0;
}

.sub-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.sub-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-size: 25rpx;
  color: #666;
  background-color: #f5f5f5;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.sub-chip.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* ===== 分类标题 ===== */
.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx 16rpx;
}

.category-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

/* ===== 商品网格 ===== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 20rpx 20rpx;
}

.product-item {
  width: calc(50% - 16rpx);
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.product-item:nth-child(odd) {
  margin-right: 32rpx;
}

.product-item:active {
  transform: scale(0.97);
}

.product-image {
  width: 100%;
  height: 260rpx;
  background-color: #f5f5f5;
}

.product-info {
  padding: 18rpx 20rpx;
}

.product-name {
  font-size: 26rpx;
  color: #222;
  font-weight: 500;
  line-height: 1.4;
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.product-category {
  font-size: 20rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 没有更多 ===== */
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #ccc;
  font-size: 24rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
