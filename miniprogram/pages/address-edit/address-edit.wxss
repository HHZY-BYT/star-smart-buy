/* pages/address-edit/address-edit.wxss */
.address-edit-page {
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 表单 */
.form-section {
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-picker {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-picker text:first-child {
  font-size: 28rpx;
  color: #333;
}

.form-picker .placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.form-textarea {
  flex: 1;
  height: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.default-item {
  justify-content: space-between;
}

.default-item .form-label {
  width: auto;
}

/* 保存按钮 */
.save-btn {
  background-color: var(--primary-color);
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.save-btn.disabled {
  background-color: #ccc;
}