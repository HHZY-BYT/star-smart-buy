<!--pages/create-order/create-order.wxml-->
<view class="create-order-page">
  <!-- 收货地址 -->
  <view class="address-section card" bindtap="onSelectAddress">
    <view class="address-content" wx:if="{{address}}">
      <view class="address-icon">📍</view>
      <view class="address-info">
        <view class="address-row">
          <text class="address-name">{{address.receiver}}</text>
          <text class="address-phone">{{address.phone}}</text>
        </view>
        <text class="address-detail">{{address.province}}{{address.city}}{{address.district}}{{address.detail}}</text>
      </view>
      <text class="address-arrow">›</text>
    </view>
    <view class="address-empty" wx:else>
      <text class="empty-text">请选择收货地址</text>
      <text class="address-arrow">›</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-section card">
    <view class="section-title">商品信息</view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{items}}" wx:key="productId">
        <image class="goods-image" src="{{item.image || 'https://neeko-copilot.bytedance.net/api/text_to_image?prompt=product%20placeholder%20image%20gray%20background&image_size=square'}}" mode="aspectFill"></image>
        <view class="goods-info">
          <text class="goods-name text-ellipsis-2">{{item.productName}}</text>
          <view class="goods-spec" wx:if="{{item.specValue}}">{{item.specName}}: {{item.specValue}}</view>
          <view class="goods-meta">
            <text class="goods-price">¥{{item.priceText}}</text>
            <text class="goods-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="remark-section card">
    <view class="section-title">订单备注</view>
    <textarea 
      class="remark-input" 
      placeholder="选填，请输入备注信息" 
      value="{{remark}}"
      bindinput="onRemarkInput"
      maxlength="200"
    ></textarea>
  </view>

  <!-- 价格明细 -->
  <view class="price-section card">
    <view class="price-item">
      <text class="price-label">商品总额</text>
      <text class="price-value">¥{{totalPrice}}</text>
    </view>
    <view class="price-item">
      <text class="price-label">运费</text>
      <text class="price-value">¥0.00</text>
    </view>
    <view class="price-item total">
      <text class="price-label">实付款</text>
      <text class="price-value total-price">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 底部提交栏 -->
  <view class="footer-bar safe-area-bottom">
    <view class="footer-info">
      <text class="footer-label">合计:</text>
      <text class="footer-price">¥{{totalPrice}}</text>
    </view>
    <view class="submit-btn {{loading ? 'disabled' : ''}}" bindtap="onSubmit">
      <text>提交订单</text>
    </view>
  </view>
</view>