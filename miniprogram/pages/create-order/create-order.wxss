/* pages/create-order/create-order.wxss */
.create-order-page {
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 收货地址 */
.address-section {
  margin-bottom: 20rpx;
}

.address-content {
  display: flex;
  align-items: center;
}

.address-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.address-info {
  flex: 1;
}

.address-row {
  display: flex;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
}

.address-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.address-empty {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 商品列表 */
.goods-section, .remark-section, .price-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.goods-list {
  border-top: 1rpx solid #e8e8e8;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.goods-price {
  font-size: 26rpx;
  color: #ff4d4f;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999;
}

/* 备注 */
.remark-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #333;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

/* 价格明细 */
.price-list {
  border-top: 1rpx solid #e8e8e8;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.price-item:last-child {
  border-bottom: none;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 26rpx;
  color: #333;
}

.price-item.total {
  padding-top: 20rpx;
}

.total-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

/* 底部提交栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  border-top: 1rpx solid #e8e8e8;
  padding: 20rpx;
}

.footer-info {
  display: flex;
  align-items: baseline;
}

.footer-label {
  font-size: 28rpx;
  color: #333;
}

.footer-price {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-left: 8rpx;
}

.submit-btn {
  background-color: #ff4d4f;
  color: #fff;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}