/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.search-input {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 48rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(79, 172, 254, 0.3);
}

.search-input .icon-search {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input .placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 轮播图 */
.banner-section {
  padding: 20rpx;
}

.banner-swiper {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 公告栏 */
.notice-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 20rpx 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.15);
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-swiper {
  flex: 1;
  height: 44rpx;
  line-height: 44rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #8a6d3b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分类入口 */
.category-section {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #fff 0%, #fefefe 100%);
  margin: 0 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.category-item:active {
  background-color: rgba(79, 172, 254, 0.08);
  transform: scale(0.95);
}

.category-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* AI助手入口 */
.ai-entry {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
}

.ai-icon {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.ai-content {
  flex: 1;
}

.ai-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.ai-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.ai-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 区块 */
.section {
  margin: 24rpx;
  background: linear-gradient(135deg, #fff 0%, #fefefe 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-more {
  font-size: 26rpx;
  color: #888;
}

/* 热门商品 */
.hot-products {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.hot-products .product-item {
  width: 48%;
  background: linear-gradient(135deg, #fff 0%, #fafafa 100%);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.hot-products .product-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.hot-products .product-image {
  width: 100%;
  height: 320rpx;
}

.hot-products .product-info {
  padding: 20rpx;
}

.hot-products .product-name {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
  height: 80rpx;
  line-height: 40rpx;
  margin-bottom: 12rpx;
}

.hot-products .product-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff6b6b;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background: linear-gradient(135deg, #fff 0%, #fafafa 100%);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.product-card-image {
  width: 100%;
  height: 320rpx;
}

.product-card-info {
  padding: 20rpx;
}

.product-card-name {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
  height: 80rpx;
  line-height: 40rpx;
  margin-bottom: 12rpx;
}

.product-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-card-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff6b6b;
}

.product-sales {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #bbb;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-state text:first-child {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state text:last-child {
  font-size: 28rpx;
  color: #999;
}
