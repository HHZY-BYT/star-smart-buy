/* pages/ai-chat/ai-chat.wxss */

page {
  background-color: #f0f2f5;
}

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* ========== 顶部装饰 ========= */
.header-deco {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.deco-1 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  top: -100rpx;
  right: -50rpx;
}

.deco-2 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  top: 100rpx;
  left: -80rpx;
}

.deco-3 {
  width: 150rpx;
  height: 150rpx;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  bottom: -30rpx;
  left: 40%;
}

/* ========== 消息列表 ========= */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 180rpx;
  z-index: 1;
  height: 0; /* 配合flex:1让scroll-view正确计算高度 */
}

/* ========== 欢迎消息区域（特殊样式）========== */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
  margin-bottom: 20rpx;
}

.welcome-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.35);
}

.avatar-icon {
  font-size: 56rpx;
  color: #fff;
}

.welcome-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(10px);
}

.welcome-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.welcome-title text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 1rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background-color: #52c41a;
  margin-left: 12rpx;
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.85); }
}

.welcome-content text {
  font-size: 27rpx;
  color: #5a5a6e;
  line-height: 1.75;
  white-space: pre-line;
  display: block;
}

.capability-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  flex-wrap: wrap;
}

.tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}

.tag-icon {
  font-size: 26rpx;
}

.tag text:last-child {
  font-size: 23rpx;
  color: #667eea;
  font-weight: 500;
}

/* ========== 消息项通用 ========= */
.message-item {
  display: flex;
  margin-bottom: 36rpx;
  align-items: flex-start;
}

.message-item.ai {
  justify-content: flex-start;
}

.message-item.user {
  justify-content: flex-end;
}

/* ========== 头像 ========= */
.msg-avatar {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.ai-avatar-wrap {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin-right: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

.user-avatar-wrap {
  background: linear-gradient(135deg, #ff9a44 0%, #fc6076 100%);
  margin-left: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 68, 0.25);
}

.avatar-emoji {
  font-size: 38rpx;
}

.typing-shake {
  animation: gentle-shake 1.5s ease-in-out infinite;
}

@keyframes gentle-shake {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

/* ========== 消息体 ========= */
.msg-body {
  max-width: calc(100% - 140rpx);
}

.ai-body {
  /* AI消息左对齐 */
}

.user-body {
  display: flex;
  flex-direction: row-reverse;
  align-items: flex-end;
}

/* ========== 气泡 ========= */
.bubble {
  padding: 26rpx 30rpx;
  border-radius: 24rpx;
  font-size: 29rpx;
  line-height: 1.65;
  word-break: break-all;
}

.ai-bubble {
  background: rgba(255, 255, 255, 0.95);
  color: #2d2d3a;
  border-top-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.user-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-top-right-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  backdrop-filter: blur(4px);
}

.msg-text {
  display: block;
}

/* ========== 推荐商品卡片 ========= */
.product-cards {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.product-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-img {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.card-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-name {
  font-size: 27rpx;
  color: #1a1a2e;
  font-weight: 600;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.card-price {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: 700;
}

.card-action {
  font-size: 23rpx;
  color: #667eea;
  font-weight: 500;
}

/* ========== 正在输入动画 ========= */
.typing-area {
  display: flex;
  align-items: flex-start;
  margin-bottom: 36rpx;
}

.typing-bubble {
  min-width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.typing-dots {
  display: flex;
  gap: 10rpx;
  padding: 8rpx 0;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background-color: #a0a0b0;
}

.dot-1 { animation: typing-bounce 1.4s ease-in-out infinite 0s; }
.dot-2 { animation: typing-bounce 1.4s ease-in-out infinite 0.2s; }
.dot-3 { animation: typing-bounce 1.4s ease-in-out infinite 0.4s; }

@keyframes typing-bounce {
  0%, 60%, 100% { 
    transform: translateY(0); 
    opacity: 0.4;
    background-color: #b0b0c0;
  }
  30% { 
    transform: translateY(-12rpx); 
    opacity: 1;
    background-color: #667eea;
  }
}

/* ========== 快捷提问 ========= */
.quick-panel {
  z-index: 2;
  padding: 0 24rpx 16rpx;
  background: transparent;
}

.quick-scroll {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.quick-scroll::-webkit-scrollbar {
  display: none;
}

.quick-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 26rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.quick-chip:active {
  transform: scale(0.95);
  background: rgba(102, 126, 234, 0.08);
}

.chip-icon {
  font-size: 28rpx;
}

.chip-text {
  font-size: 25rpx;
  color: #4a4a5a;
  white-space: nowrap;
  font-weight: 500;
}

/* ========== 输入面板 ========= */
.input-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 16rpx 20rpx 20rpx;
  background: linear-gradient(to top, rgba(240, 242, 245, 0.98) 70%, rgba(240, 242, 245, 0));
  backdrop-filter: blur(20px);
}

.input-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 48rpx;
  padding: 8rpx 8rpx 8rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.chat-input {
  flex: 1;
  font-size: 29rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.input-placeholder {
  color: #b0b0c0;
  font-size: 27rpx;
}

.send-btn {
  position: relative;
  width: 112rpx;
  height: 72rpx;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  flex-shrink: 0;
}

.send-btn-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 40rpx;
  background: #d0d0dc;
  transition: all 0.3s ease;
}

.send-btn.active .send-btn-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.send-text {
  position: relative;
  z-index: 1;
  font-size: 27rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
}
