/* pages/user/user.wxss */
.user-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f5f5 30%);
}

.user-header {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  padding: 80rpx 32rpx 60rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 172, 254, 0.3);
}

.user-not-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
}

.user-avatar:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.default-avatar {
  background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
}

.user-info {
  text-align: center;
  margin-bottom: 32rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.edit-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 12rpx;
  padding: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.user-phone-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-btn {
  background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
  color: #4facfe;
  border: none;
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 255, 255, 0.4);
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.user-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.order-section {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #888;
}

.section-more .arrow {
  margin-left: 8rpx;
  font-size: 32rpx;
}

.order-tabs {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0 32rpx;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.order-tab:active {
  background-color: rgba(79, 172, 254, 0.1);
  transform: scale(0.96);
}

.tab-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.tab-text {
  font-size: 26rpx;
  color: #555;
  font-weight: 500;
}

.tab-count {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 24rpx;
  min-width: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
}

.function-section {
  margin: 0 24rpx 24rpx;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s ease;
}

.function-item:active {
  background-color: #f8f9fa;
}

.function-item:last-child {
  border-bottom: none;
}

.function-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 20rpx;
}

.function-name {
  flex: 1;
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
}

.function-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.logout-btn {
  margin: 32rpx 24rpx 48rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #fff 0%, #f8f8f8 100%);
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.logout-btn:active {
  background-color: #f0f0f0;
}

.card {
  background: linear-gradient(135deg, #fff 0%, #fefefe 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  padding: 40rpx 32rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.modal-input:focus {
  border-color: #4facfe;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn.confirm {
  color: #4facfe;
}

.login-modal {
  width: 640rpx;
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.phone-input {
  width: 100%;
}

.code-input {
  flex: 1;
  margin-right: 16rpx;
}

.send-code-btn {
  width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 0;
  border: none;
}

.send-code-btn.disabled {
  background: #e8e8e8;
  color: #999;
}

.login-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.function-item.danger {
  color: #f56c6c;
}

.function-item.danger .function-name {
  color: #f56c6c;
}

.personal-info {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
}

.section-title-row {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.info-list {
  padding: 16rpx 0;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: background-color 0.2s ease;
}

.info-item:active {
  background-color: #f8f9fa;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.info-value-row {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.info-value {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
}

.info-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.account-section {
  margin: 0 24rpx 24rpx;
}

.account-list {
  padding: 8rpx 0;
}

.account-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: background-color 0.2s ease;
}

.account-item:active {
  background-color: #f8f9fa;
}

.account-label {
  flex: 1;
  font-size: 28rpx;
  color: #222;
}

.account-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.account-item.danger .account-label {
  color: #f56c6c;
}

.login-tip-code {
  display: block;
  font-size: 24rpx;
  color: #4facfe;
  margin-top: 8rpx;
}
