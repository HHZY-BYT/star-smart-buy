<!--pages/user/user.wxml-->
<view class="user-page">
  <view class="user-header" wx:if="{{!isLoggedIn}}">
    <view class="header-bg"></view>
    <view class="user-not-login">
      <image class="user-avatar default-avatar" src="/images/default-avatar.png"></image>
      <view class="user-info">
        <text class="user-name">未登录</text>
        <text class="user-desc">登录后享受更多服务</text>
      </view>
      <button class="login-btn" bindtap="onLogin">登录</button>
    </view>
  </view>
  
  <view class="user-header" wx:else>
    <view class="header-bg"></view>
    <view class="user-logged-in">
      <image class="user-avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" bindtap="onAvatarTap"></image>
      <view class="user-info">
        <view class="user-name-row">
          <text class="user-name">{{userInfo.nickname}}</text>
          <text class="edit-icon" bindtap="showNicknameInput">✎</text>
        </view>
        <text class="user-id">ID: {{userInfo.userId}}</text>
      </view>
    </view>
  </view>

  <view class="personal-info card" wx:if="{{isLoggedIn}}">
    <view class="section-title-row">
      <text class="section-icon">👤</text>
      <text class="section-title">个人信息</text>
    </view>
    <view class="info-list">
      <view class="info-item" bindtap="showNicknameInput">
        <text class="info-label">昵称</text>
        <view class="info-value-row">
          <text class="info-value">{{userInfo.nickname}}</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
      <view class="info-item" bindtap="showPhoneInput">
        <text class="info-label">手机号</text>
        <view class="info-value-row">
          <text class="info-value">{{userInfo.phone || '未绑定'}}</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
      <view class="info-item" bindtap="onAvatarTap">
        <text class="info-label">头像</text>
        <view class="info-value-row">
          <text class="info-value">点击更换</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="order-section card" wx:if="{{isLoggedIn}}">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="section-more" bindtap="onOrderTap">
        <text>全部订单</text>
        <text class="arrow">›</text>
      </view>
    </view>
    
    <view class="order-tabs">
      <view class="order-tab" bindtap="onOrderTap" data-status="0">
        <view class="tab-icon">💰</view>
        <text class="tab-text">待付款</text>
        <view class="tab-count" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-status="1">
        <view class="tab-icon">📦</view>
        <text class="tab-text">待发货</text>
        <view class="tab-count" wx:if="{{orderCounts.paid > 0}}">{{orderCounts.paid}}</view>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-status="2">
        <view class="tab-icon">🚚</view>
        <text class="tab-text">待收货</text>
        <view class="tab-count" wx:if="{{orderCounts.shipped > 0}}">{{orderCounts.shipped}}</view>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-status="3">
        <view class="tab-icon">✅</view>
        <text class="tab-text">已完成</text>
        <view class="tab-count" wx:if="{{orderCounts.completed > 0}}">{{orderCounts.completed}}</view>
      </view>
    </view>
  </view>

  <view class="function-section card" wx:if="{{isLoggedIn}}">
    <view class="function-item" bindtap="onMyReviewsTap">
      <view class="function-icon">⭐</view>
      <text class="function-name">我的评价</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onAddressTap">
      <view class="function-icon">📍</view>
      <text class="function-name">收货地址</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onAiChatTap">
      <view class="function-icon">🤖</view>
      <text class="function-name">AI智能助手</text>
      <text class="function-arrow">›</text>
    </view>
  </view>

  <view class="account-section card" wx:if="{{isLoggedIn}}">
    <view class="section-title-row">
      <text class="section-icon">⚙️</text>
      <text class="section-title">账户安全</text>
    </view>
    <view class="account-list">
      <view class="account-item danger" bindtap="showDeleteConfirm">
        <text class="account-label">注销账户</text>
        <text class="account-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="onLogout">
    <text>退出登录</text>
  </view>

  <view class="modal" wx:if="{{showPhoneModal}}" bindtap="hidePhoneModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{userInfo.phone ? '修改手机号' : '绑定手机号'}}</text>
        <text class="modal-close" bindtap="hidePhoneModal">✕</text>
      </view>
      <view class="modal-body">
        <input class="modal-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput"></input>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hidePhoneModal">取消</button>
        <button class="modal-btn confirm" bindtap="savePhone">保存</button>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showNicknameModal}}" bindtap="hideNicknameModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改昵称</text>
        <text class="modal-close" bindtap="hideNicknameModal">✕</text>
      </view>
      <view class="modal-body">
        <input class="modal-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput"></input>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideNicknameModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveNickname">保存</button>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showLoginModal}}" bindtap="closeLoginModal">
    <view class="modal-content login-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">手机号登录</text>
        <text class="modal-close" bindtap="closeLoginModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="input-row">
          <input class="modal-input phone-input" type="number" placeholder="请输入手机号" value="{{loginPhone}}" bindinput="onLoginPhoneInput"></input>
        </view>
        <view class="input-row">
          <input class="modal-input code-input" type="number" placeholder="请输入6位验证码" value="{{loginVerifyCode}}" bindinput="onVerifyCodeInput"></input>
          <button class="send-code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendVerifyCode">
            {{countdown > 0 ? countdown + '秒后重发' : '发送验证码'}}
          </button>
        </view>
        <text class="login-tip">仅限已注册用户，未注册请使用微信登录</text>
        <text class="login-tip-code">模拟验证码：123456</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeLoginModal">取消</button>
        <button class="modal-btn confirm" bindtap="onPhoneLogin">登录</button>
      </view>
    </view>
  </view>
</view>