.review-page {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 商品信息 */
.goods-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.goods-price {
  font-size: 26rpx;
  color: #999;
}

/* 评分 */
.rating-stars {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.star {
  font-size: 56rpx;
  color: #ddd;
  transition: color 0.2s;
}

.star.active {
  color: #ff9800;
}

.rating-text {
  font-size: 30rpx;
  color: #ff9800;
  font-weight: 600;
  margin-left: 16rpx;
}

/* 评价内容 */
.content-section {
  position: relative;
}

.review-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 图片上传 */
.image-count {
  font-size: 24rpx;
  font-weight: 400;
  color: #999;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.review-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  border-radius: 50%;
}

.image-add {
  width: 180rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
}

.add-icon {
  font-size: 56rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 40rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
