<!--pages/refund/refund.wxml-->
<view class="refund-page">
  <!-- 退款类型提示 -->
  <view class="refund-type-card {{canQuickRefund ? 'quick' : 'apply'}}">
    <view class="type-icon">{{canQuickRefund ? '⚡' : '📋'}}</view>
    <view class="type-info">
      <text class="type-title">{{refundTypeText}}</text>
      <text class="type-desc">{{refundTypeDesc}}</text>
      <text class="type-time" wx:if="{{canQuickRefund}}">剩余 {{remainingHours}} 小时快速退款时效</text>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="order-section card" wx:if="{{order}}">
    <view class="section-title">退款订单</view>
    <view class="order-info">
      <text class="order-no">订单号：{{order.orderNo}}</text>
      <text class="order-amount">退款金额：<text class="amount">¥{{order.totalAmountText}}</text></text>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{items}}" wx:key="id">
        <view class="goods-info">
          <text class="goods-name">{{item.productName}}</text>
          <text class="goods-price">¥{{item.priceText}} x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退款原因 -->
  <view class="reason-section card">
    <view class="section-title">退款原因</view>
    <view class="reason-options">
      <view class="reason-item {{selectedReason === item ? 'active' : ''}}" 
        wx:for="{{reasonOptions}}" wx:key="index" 
        bindtap="onReasonSelect" data-reason="{{item}}">
        <view class="reason-radio">
          <view class="radio-dot" wx:if="{{selectedReason === item}}"></view>
        </view>
        <text>{{item}}</text>
      </view>
    </view>
    <view class="custom-reason">
      <input class="custom-input" placeholder="其他原因（请输入）" 
        value="{{customReason}}" bindinput="onCustomReasonInput" />
    </view>
  </view>

  <!-- 补充说明 -->
  <view class="desc-section card">
    <view class="section-title">补充说明（选填）</view>
    <textarea class="desc-textarea" 
      placeholder="请详细描述退款原因，有助于加快审核..." 
      value="{{description}}" 
      bindinput="onDescriptionInput"
      maxlength="500"
    ></textarea>
    <text class="char-count">{{description.length}}/500</text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn {{canQuickRefund ? 'quick' : ''}}" 
      bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : (canQuickRefund ? '快速退款' : '提交退款申请')}}
    </button>
  </view>
</view>
