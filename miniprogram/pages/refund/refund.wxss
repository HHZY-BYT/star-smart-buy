.refund-page {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 退款类型提示 */
.refund-type-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.refund-type-card.quick {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  border: 2rpx solid #91d5ff;
}

.refund-type-card.apply {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  border: 2rpx solid #ffd591;
}

.type-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.type-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.type-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 26rpx;
  color: #666;
}

.type-time {
  font-size: 24rpx;
  color: #1890ff;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 订单信息 */
.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 26rpx;
  color: #666;
}

.order-amount {
  font-size: 26rpx;
  color: #333;
}

.amount {
  color: #ff4d4f;
  font-weight: 600;
  font-size: 30rpx;
}

.goods-item {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.goods-item:first-child {
  border-top: none;
}

.goods-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.goods-price {
  font-size: 26rpx;
  color: #999;
}

/* 退款原因 */
.reason-options {
  margin-bottom: 20rpx;
}

.reason-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.reason-item:last-child {
  border-bottom: none;
}

.reason-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.reason-item.active .reason-radio {
  border-color: #1890ff;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #1890ff;
}

.reason-item.active {
  color: #1890ff;
  font-weight: 500;
}

.custom-reason {
  margin-top: 16rpx;
}

.custom-input {
  width: 100%;
  height: 72rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 补充说明 */
.desc-section {
  position: relative;
}

.desc-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 30rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.submit-btn.quick {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.submit-btn[disabled] {
  opacity: 0.6;
}
